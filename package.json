{
	"private": true,
	"name": "clankermux",
	"description": "A load balancer proxy for Claude Code with intelligent load balancing across multiple accounts",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"clankermux": "bun run build && bun run start",
		"dev": "bun run dev:server",
		"start": "bun run apps/server/src/server.ts",
		"server": "bun run apps/server/src/server.ts",
		"dev:server": "bun run --hot apps/server/src/server.ts",
		"dev:dashboard": "bun --hot packages/dashboard-web/src/index.tsx",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun test",
		"build": "echo \"🏗️  Building ClankerMux v$(node -p \"require('./package.json').version\")\" && bun run build:db-workers && bun run build:dashboard",
		"build:db-workers": "bun run --cwd packages/database build:workers",
		"build:db-workers:guarded": "bun run scripts/guarded-build.ts db-workers",
		"build:dashboard": "bun run --cwd packages/dashboard-web build",
		"build:dashboard:guarded": "bun run scripts/guarded-build.ts dashboard",
		"build:lander": "bun run --cwd apps/lander build",
		"format": "bunx biome format --write .",
		"lint": "bunx --bun biome check --write --unsafe .",
		"restart": "./scripts/restart.sh"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/bun": "1.3.14",
		"bun-types": "1.3.14",
		"typescript": "6.0.2"
	},
	"version": "2026.7.22"
}
