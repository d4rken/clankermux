{
	"name": "@clankermux/server",
	"version": "0.1.0",
	"type": "module",
	"main": "./src/server.ts",
	"scripts": {
		"dev": "bun run --hot src/server.ts",
		"start": "bun run src/server.ts",
		"build": "bun build src/server.ts --compile --outfile dist/better-ccflare-server",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"@clankermux/core": "workspace:*",
		"@clankermux/core-di": "workspace:*",
		"@clankermux/database": "workspace:*",
		"@clankermux/config": "workspace:*",
		"@clankermux/logger": "workspace:*",
		"@clankermux/load-balancer": "workspace:*",
		"@clankermux/proxy": "workspace:*",
		"@clankermux/openai-responses-adapter": "workspace:*",
		"@clankermux/dashboard-web": "workspace:*",
		"@clankermux/http-api": "workspace:*",
		"@clankermux/security": "workspace:*",
		"@clankermux/types": "workspace:*"
	}
}
